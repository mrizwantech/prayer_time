# Ensure consistent line endings across all platforms
* text=auto

# Swift
*.swift text eol=lf

# Kotlin/Gradle
*.kt text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf

# Dart/Flutter
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# JSON
*.json text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# C/C++
*.h text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cmake text eol=lf

# XML
*.xml text eol=lf

# Web
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf

# Markdown
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.tar binary
*.gz binary
*.aab binary
*.apk binary
